# Environment Configuration for Exomiser UI
# Copy this file to .env and customize values for your environment

# Application Configuration
PORT=8000
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-this-in-production

# Java/Memory Configuration
MAX_MEMORY=2g
JAVA_OPTS=-Xms1g -Xmx2g

# Gunicorn Configuration (for production)
GUNICORN_WORKERS=2
GUNICORN_THREADS=4

# Database Configuration
# DATABASE_URL=sqlite:////opt/instance/app.db  # Default SQLite
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  # PostgreSQL example

# Exomiser Configuration
EXOMISER_VERSION=14.1.0

# AutoHPO - LLM Configuration (OpenAI-compatible local LLM)
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL_ID=qwen2.5-7b-instruct
OPENAI_API_KEY=NA

# AutoHPO - Meilisearch Configuration
MEILISEARCH_URL=http://localhost:7700
MEILI_MASTER_KEY=

# AutoHPO - Embedding (optional, enables hybrid search)
# HPO_EMBEDDING_MODEL=all-MiniLM-L6-v2
# HPO_EMBEDDING_DIMENSIONS=384

# Development vs Production
# For production, set:
# FLASK_ENV=production
# FLASK_DEBUG=0
# SECRET_KEY=your-secure-random-secret-key
# MAX_MEMORY=4g
# GUNICORN_WORKERS=4
